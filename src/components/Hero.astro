<section id="inicio" class="relative flex items-center justify-center overflow-hidden" style="min-height: 100svh; min-height: -webkit-fill-available;">

  <!-- Particle canvas -->
  <canvas id="particle-canvas" class="absolute inset-0 w-full h-full"></canvas>

  <!-- Radial vignette — lighter in light mode (see .hero-vignette in global.css) -->
  <div class="absolute inset-0 pointer-events-none hero-vignette"></div>

  <!-- Hero content -->
  <div class="relative z-10 text-center px-6 max-w-4xl mx-auto pt-20">

    <!-- Logo mark -->
    <div class="flex justify-center mb-8 reveal">
      <img src="/images/velaris_white_logo_no_background.png" alt="Velaris"
        class="hidden dark:block w-24 h-24 md:w-32 md:h-32 animate-logo-pulse select-none" />
      <img src="/images/velaris_black_logo_no_background.png" alt="Velaris"
        class="block dark:hidden w-24 h-24 md:w-32 md:h-32 animate-logo-pulse select-none"
        style="filter: drop-shadow(0 0 22px rgba(108,99,255,0.5));" />
    </div>

    <!-- Eyebrow -->
    <p class="section-label reveal reveal-delay-1">Agencia de Desarrollo Web</p>

    <!-- Headline -->
    <h1 class="font-display font-black text-4xl sm:text-5xl md:text-6xl lg:text-7xl tracking-tight leading-tight mb-5 reveal reveal-delay-1">
      <span class="gradient-text">Built for performance.</span><br />
      <span style="color: var(--text);">Scaled for growth.</span>
    </h1>

    <!-- Subheadline -->
    <p class="font-body text-lg md:text-xl lg:text-2xl max-w-2xl mx-auto mb-10 leading-relaxed reveal reveal-delay-2" style="color: var(--muted);">
      Transformamos negocios con tecnología web de
      <strong style="color: var(--text); font-weight: 600;">alto impacto</strong>
      — rápida, segura y diseñada para convertir visitantes en clientes reales.
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row gap-4 justify-center items-center reveal reveal-delay-3">
      <a
        href="https://wa.me/573171509336?text=Hola%2C%20me%20interesa%20cotizar%20un%20proyecto%20con%20Velaris."
        target="_blank" rel="noopener noreferrer"
        id="hero-whatsapp-cta" class="btn-primary"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="19" height="19" fill="currentColor" viewBox="0 0 16 16">
          <path d="M13.601 2.326A7.854 7.854 0 0 0 7.994 0C3.627 0 .068 3.558.064 7.926c0 1.399.366 2.76 1.057 3.965L0 16l4.204-1.102a7.933 7.933 0 0 0 3.79.965h.004c4.368 0 7.926-3.558 7.93-7.93A7.898 7.898 0 0 0 13.6 2.326zM7.994 14.521a6.573 6.573 0 0 1-3.356-.92l-.24-.144-2.494.654.666-2.433-.156-.251a6.56 6.56 0 0 1-1.007-3.505c0-3.626 2.957-6.584 6.591-6.584a6.56 6.56 0 0 1 4.66 1.931 6.557 6.557 0 0 1 1.928 4.66c-.004 3.639-2.961 6.592-6.592 6.592zm3.615-4.934c-.197-.099-1.17-.578-1.353-.646-.182-.065-.315-.099-.445.099-.133.197-.513.646-.627.775-.114.133-.232.148-.43.05-.197-.1-.836-.308-1.592-.985-.59-.525-.985-1.175-1.103-1.372-.114-.198-.011-.304.088-.403.087-.088.197-.232.296-.346.1-.114.133-.198.198-.33.065-.134.034-.248-.015-.347-.05-.099-.445-1.076-.612-1.47-.16-.389-.323-.335-.445-.34-.114-.007-.247-.007-.38-.007a.729.729 0 0 0-.529.247c-.182.198-.691.677-.691 1.654 0 .977.71 1.916.81 2.049.098.133 1.394 2.132 3.383 2.992.47.205.84.326 1.129.418.475.152.904.129 1.246.08.38-.058 1.171-.48 1.338-.943.164-.464.164-.86.114-.943-.049-.084-.182-.133-.38-.232z"/>
        </svg>
        Cotiza por WhatsApp
      </a>
      <a href="#servicios" id="hero-services-link" class="btn-secondary">
        Ver servicios
        <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
        </svg>
      </a>
    </div>

    <!-- Trust badges -->
    <div class="mt-14 flex flex-wrap justify-center gap-x-8 gap-y-3 reveal reveal-delay-4">
      {[
        ['⚡', 'Carga instantánea'],
        ['🔒', 'Seguridad máxima'],
        ['🎓', 'Equipo profesional'],
        ['🚀', 'Despliegue global'],
      ].map(([icon, label]) => (
        <span class="flex items-center gap-1.5 text-xs font-medium" style="color: var(--muted);">
          <span>{icon}</span><span>{label}</span>
        </span>
      ))}
    </div>
  </div>

</section>

<script is:inline>
(function () {
  var canvas = document.getElementById('particle-canvas');
  if (!canvas) return;
  var ctx = canvas.getContext('2d');
  var W = canvas.width  = window.innerWidth;
  var H = canvas.height = window.innerHeight;
  var mouse = { x: -9999, y: -9999 };

  var isMobile = W < 768;
  var COUNT  = isMobile ? 50 : 95;
  var MDIST  = isMobile ? 100 : 150;

  function rand(min, max) { return Math.random() * (max - min) + min; }

  function makeParticle() {
    var bx = rand(-0.25, 0.25);
    var by = rand(-0.25, 0.25);
    // Ensure base velocity isn't too close to zero
    if (Math.abs(bx) < 0.05) bx = bx < 0 ? -0.1 : 0.1;
    if (Math.abs(by) < 0.05) by = by < 0 ? -0.1 : 0.1;

    return {
      x: rand(0, W), y: rand(0, H),
      baseVx: bx, baseVy: by,
      vx: 0, vy: 0,
      r:  rand(0.8, 2.2),
      o:  rand(0.3, 0.7),   // higher base opacity so they show in light mode
    };
  }

  var particles = [];
  for (var i = 0; i < COUNT; i++) particles.push(makeParticle());

  function tick() {
    var isDark = document.documentElement.classList.contains('dark');
    ctx.clearRect(0, 0, W, H);

    for (var i = 0; i < particles.length; i++) {
      var p = particles[i];

      // Mouse repulsion (desktop only)
      if (!isMobile) {
        var dx = p.x - mouse.x, dy = p.y - mouse.y;
        var d  = Math.sqrt(dx * dx + dy * dy);
        if (d < 120 && d > 0) {
          var f = (120 - d) / 120;
          p.vx += (dx / d) * f * 0.4;
          p.vy += (dy / d) * f * 0.4;
        }
      }

      // Friction only affects the mouse push
      p.vx *= 0.94; p.vy *= 0.94;

      // Add forces together
      p.x += p.baseVx + p.vx; 
      p.y += p.baseVy + p.vy;

      // Bounce off walls
      if (p.x < 0 || p.x > W) { p.baseVx *= -1; p.vx *= -1; p.x = Math.max(0, Math.min(W, p.x)); }
      if (p.y < 0 || p.y > H) { p.baseVy *= -1; p.vy *= -1; p.y = Math.max(0, Math.min(H, p.y)); }

      // Dark mode: violet glow particles
      // Light mode: darker, more opaque so they're visible on white
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
      ctx.fillStyle = isDark
        ? 'rgba(108,99,255,' + (p.o * 2.0) + ')'
        : 'rgba(55,48,163,'  + (p.o * 2.5) + ')';
      ctx.fill();
    }

    // Connections
    for (var i = 0; i < particles.length - 1; i++) {
      for (var j = i + 1; j < particles.length; j++) {
        var ax = particles[i].x - particles[j].x;
        var ay = particles[i].y - particles[j].y;
        var dist = Math.sqrt(ax * ax + ay * ay);
        if (dist < MDIST) {
          // Both modes get much thicker, darker lines
          var alpha = (1 - dist / MDIST) * (isDark ? 0.6 : 0.95);
          ctx.beginPath();
          ctx.strokeStyle = isDark
            ? 'rgba(108,99,255,' + alpha + ')'
            : 'rgba(55,48,163,' + alpha + ')';
          ctx.lineWidth = isDark ? 1.0 : 1.8;
          ctx.moveTo(particles[i].x, particles[i].y);
          ctx.lineTo(particles[j].x, particles[j].y);
          ctx.stroke();
        }
      }
    }
    requestAnimationFrame(tick);
  }
  tick();

  window.addEventListener('mousemove',  function (e) { mouse.x = e.clientX; mouse.y = e.clientY; });
  window.addEventListener('mouseleave', function ()  { mouse.x = -9999; mouse.y = -9999; });
  
  var lastW = window.innerWidth;
  window.addEventListener('resize', function () {
    // Ignore height-only changes on mobile (caused by address bar show/hide on scroll)
    var newW = window.innerWidth;
    if (isMobile && newW === lastW) return;
    
    lastW = newW;
    W = canvas.width  = newW;
    H = canvas.height = window.innerHeight;
    isMobile = W < 768;
    
    // Re-distribute particles if window gets much bigger
    for (var i = 0; i < particles.length; i++) {
      if (particles[i].x > W) particles[i].x = rand(0, W);
      if (particles[i].y > H) particles[i].y = rand(0, H);
    }
  });
})();
</script>
