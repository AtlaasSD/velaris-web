---
const navLinks = [
  { href: '#servicios',  label: 'Servicios' },
  { href: '#tecnologia', label: 'Tecnología' },
  { href: '#valor',      label: 'Valor' },
  { href: '#nosotros',   label: 'Nosotros' },
];
---

<footer>
  <div class="footer-divider"></div>

  <div class="py-16 md:py-20 px-5 md:px-8" style="background: var(--bg);">
    <div class="max-w-7xl mx-auto">

      <!-- Top: logo + tagline -->
      <div class="flex flex-col items-center text-center mb-12 md:mb-16">
        <!-- Logo -->
        <a href="#inicio" aria-label="Velaris — Inicio" class="mb-6 block">
          <img src="/images/white_logo_with_title_no_bg.png" alt="Velaris" class="hidden dark:block h-9 w-auto mx-auto" />
          <img src="/images/black_logo_with_title_no_bg.png" alt="Velaris" class="block dark:hidden h-9 w-auto mx-auto" />
        </a>

        <!-- Tagline -->
        <h2 class="font-display font-black text-2xl sm:text-3xl md:text-4xl max-w-2xl mb-4" style="color: var(--text);">
          Lleva tu presencia digital<br class="hidden sm:block" />
          <span class="gradient-text">al siguiente nivel.</span>
        </h2>
        <p class="text-base max-w-md" style="color: var(--muted);">
          Construyamos el futuro de tu negocio hoy mismo.
        </p>
      </div>

      <!-- Middle: contact + links -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-10 mb-12 md:mb-16 text-center md:text-left">

        <!-- Contact -->
        <div>
          <h3 class="font-display font-bold text-sm uppercase tracking-widest mb-4" style="color: var(--accent);">Contacto</h3>
          <ul class="flex flex-col gap-3">
            <li>
              <a
                href="mailto:contactovelarisweb@gmail.com"
                id="footer-email-link"
                class="text-sm transition-colors duration-200 hover:underline"
                style="color: var(--muted);"
              >
                contactovelarisweb@gmail.com
              </a>
            </li>
            <li>
              <a
                href="https://wa.me/573212545768?text=Hola%2C%20me%20interesa%20cotizar%20un%20proyecto%20web%20con%20Velaris."
                target="_blank"
                rel="noopener noreferrer"
                id="footer-whatsapp-link"
                class="text-sm transition-colors duration-200 hover:underline"
                style="color: var(--muted);"
              >
                +57 321 254 5768
              </a>
            </li>
          </ul>
        </div>

        <!-- Nav links -->
        <div>
          <h3 class="font-display font-bold text-sm uppercase tracking-widest mb-4" style="color: var(--accent);">Navegación</h3>
          <ul class="flex flex-col gap-2.5">
            {navLinks.map(link => (
              <li>
                <a href={link.href} class="text-sm transition-colors duration-200 hover:underline footer-nav-link" style="color: var(--muted);">
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- CTA mini -->
        <div class="flex flex-col items-center md:items-start gap-4">
          <h3 class="font-display font-bold text-sm uppercase tracking-widest" style="color: var(--accent);">¿Empezamos?</h3>
          <a
            href="https://wa.me/573212545768?text=Hola%2C%20me%20interesa%20cotizar%20un%20proyecto%20web%20con%20Velaris."
            target="_blank"
            rel="noopener noreferrer"
            id="footer-cta-btn"
            class="btn-primary"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" fill="currentColor" viewBox="0 0 16 16">
              <path d="M13.601 2.326A7.854 7.854 0 0 0 7.994 0C3.627 0 .068 3.558.064 7.926c0 1.399.366 2.76 1.057 3.965L0 16l4.204-1.102a7.933 7.933 0 0 0 3.79.965h.004c4.368 0 7.926-3.558 7.93-7.93A7.898 7.898 0 0 0 13.6 2.326zM7.994 14.521a6.573 6.573 0 0 1-3.356-.92l-.24-.144-2.494.654.666-2.433-.156-.251a6.56 6.56 0 0 1-1.007-3.505c0-3.626 2.957-6.584 6.591-6.584a6.56 6.56 0 0 1 4.66 1.931 6.557 6.557 0 0 1 1.928 4.66c-.004 3.639-2.961 6.592-6.592 6.592zm3.615-4.934c-.197-.099-1.17-.578-1.353-.646-.182-.065-.315-.099-.445.099-.133.197-.513.646-.627.775-.114.133-.232.148-.43.05-.197-.1-.836-.308-1.592-.985-.59-.525-.985-1.175-1.103-1.372-.114-.198-.011-.304.088-.403.087-.088.197-.232.296-.346.1-.114.133-.198.198-.33.065-.134.034-.248-.015-.347-.05-.099-.445-1.076-.612-1.47-.16-.389-.323-.335-.445-.34-.114-.007-.247-.007-.38-.007a.729.729 0 0 0-.529.247c-.182.198-.691.677-.691 1.654 0 .977.71 1.916.81 2.049.098.133 1.394 2.132 3.383 2.992.47.205.84.326 1.129.418.475.152.904.129 1.246.08.38-.058 1.171-.48 1.338-.943.164-.464.164-.86.114-.943-.049-.084-.182-.133-.38-.232z"/>
            </svg>
            Cotizar ahora
          </a>
        </div>

      </div>

      <!-- Bottom bar -->
      <div class="footer-divider mb-6"></div>
      <div class="flex flex-col sm:flex-row justify-between items-center gap-3 text-center">
        <p class="text-xs" style="color: var(--muted);">
          © 2025 Velaris. Todos los derechos reservados.
        </p>
        <p class="text-xs" style="color: var(--muted);">
          Hecho con ❤️ en Pereira, Colombia
        </p>
      </div>

    </div>
  </div>
</footer>

<style>
  .footer-nav-link:hover { color: var(--accent) !important; }
</style>
