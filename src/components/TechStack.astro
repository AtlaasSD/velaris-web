---
const techs = [
  { name: 'Astro',       emoji: '🚀', desc: 'Framework SSG de nueva generación', enDesc: 'Next-gen SSG Framework' },
  { name: 'Tailwind CSS',emoji: '🎨', desc: 'Estilos modernos a máxima velocidad', enDesc: 'Fast modern styling' },
  { name: 'JavaScript',  emoji: '⚡', desc: 'Lógica web moderna y dinámica', enDesc: 'Modern & dynamic web logic' },
  { name: 'React',       emoji: '⚛️', desc: 'Interfaces interactivas de alto nivel', enDesc: 'High-level interactive UI' },
  { name: 'Next.js',     emoji: '▲',  desc: 'Apps web fullstack escalables', enDesc: 'Scalable fullstack apps' },
  { name: 'Node.js',     emoji: '🟢', desc: 'Back-end veloz y eficiente', enDesc: 'Fast & efficient back-end' },
  { name: 'Git',         emoji: '📦', desc: 'Control de versiones profesional', enDesc: 'Professional version control' },
  { name: 'Netlify',     emoji: '☁️', desc: 'Despliegue global instantáneo', enDesc: 'Instant global deployment' },
  { name: 'Cloudflare',  emoji: '🛡️', desc: 'CDN de clase mundial', enDesc: 'World-class CDN' },
];

const steps = [
  {
    n: '01',
    title: 'Estrategia', enTitle: 'Strategy',
    desc: 'Entendemos tu negocio y objetivos antes de escribir la primera línea de código.', enDesc: 'We understand your business and goals before writing a single line of code.',
  },
  {
    n: '02',
    title: 'Diseño UX/UI', enTitle: 'UX/UI Design',
    desc: 'Interfaces modernas y fluidas, diseñadas específicamente para guiar al usuario.', enDesc: 'Modern and fluid interfaces, designed specifically to guide the user.',
  },
  {
    n: '03',
    title: 'Desarrollo', enTitle: 'Development',
    desc: 'Código limpio y optimizado, garantizando máxima velocidad, seguridad y escalabilidad.', enDesc: 'Clean and optimized code, ensuring maximum speed, security, and scalability.',
  },
  {
    n: '04',
    title: 'Despliegue', enTitle: 'Deployment',
    desc: 'Tu sitio distribuido globalmente, asegurando tiempos de respuesta inmediatos.', enDesc: 'Your site distributed globally, ensuring instant response times.',
  },
  {
    n: '05',
    title: 'Soporte', enTitle: 'Support',
    desc: 'Nos mantenemos a tu lado con soporte continuo para que nada frene tu operación.', enDesc: 'We stay by your side with ongoing support so nothing slows down your operation.',
  },
];

import InteractiveDotGrid from './InteractiveDotGrid.astro';
---

<section id="tecnologia" class="section-has-orbs py-24 md:py-32 px-5 md:px-8 overflow-hidden" style="background: var(--surface);">

  <!-- Interactive dot grid mapped to this section's background -->
  <InteractiveDotGrid />

  <!-- Ambient background orbs -->
  <div class="section-orbs" aria-hidden="true">
    <div class="blur-orb orb-b" style="width:450px;height:450px;background:#22D3EE;top:-80px;right:-120px;"></div>
    <div class="blur-orb orb-c" style="width:320px;height:320px;background:#6C63FF;bottom:-60px;left:-80px;"></div>
  </div>

  <div class="max-w-7xl mx-auto">

    <!-- Header -->
    <div class="text-center mb-14 md:mb-20">
      <p class="section-label reveal" data-en="Technology">Tecnología</p>
      <h2 class="font-display font-black text-3xl sm:text-4xl md:text-5xl mb-4 reveal reveal-delay-1" style="color: var(--text);" data-en="Our technology stack">
        Nuestro arsenal tecnológico
      </h2>
      <p class="max-w-xl mx-auto text-base md:text-lg reveal reveal-delay-2" style="color: var(--muted);" data-en="We use the exact same tools that the world's largest tech companies use — we just put them to work for your business.">
        Usamos las mismas herramientas que emplean las empresas tech más grandes del mundo — solo que las ponemos a trabajar para tu negocio.
      </p>
    </div>

    <!-- Tech marquee (auto-scrolling) -->
    <div class="marquee-outer mb-20 reveal reveal-delay-2">
      <div class="marquee-track">
        <!-- Duplicated for seamless infinite scroll -->
        {[...techs, ...techs].map((t, i) => (
          <div
            key={i}
            class="flex-shrink-0 mx-3 flex items-center gap-2.5 px-5 py-3 rounded-xl"
            style="background: var(--card); border: 1px solid var(--border);"
          >
            <span class="text-2xl" aria-hidden="true">{t.emoji}</span>
            <div>
              <p class="font-display font-semibold text-sm leading-tight" style="color: var(--text);">{t.name}</p>
              <p class="text-xs" style="color: var(--muted);" data-en={t.enDesc}>{t.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Workflow section -->
    <div class="text-center mb-12">
      <p class="section-label reveal" data-en="Our Process">Nuestro Proceso</p>
      <h3 class="font-display font-black text-2xl sm:text-3xl md:text-4xl reveal reveal-delay-1" style="color: var(--text);" data-en="From idea to result in clear steps">
        De la idea al resultado en pasos claros
      </h3>
    </div>

    <!-- Steps grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-5">
      {steps.map((s, i) => (
        <div class={`glow-card p-6 flex flex-col gap-4 reveal reveal-delay-${(i % 4) + 1}`} id={`step-${s.n}`}>
          <div class="step-num">{s.n}</div>
          <div>
            <h4 class="font-display font-bold text-base mb-2 leading-snug" style="color: var(--text);" data-en={s.enTitle}>{s.title}</h4>
            <p class="text-sm leading-relaxed" style="color: var(--muted);" data-en={s.enDesc}>{s.desc}</p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
