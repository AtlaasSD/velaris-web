---
---
<header id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <nav class="max-w-7xl mx-auto px-5 md:px-8 h-16 md:h-20 flex items-center justify-between gap-4">

    <!-- Logo -->
    <a href="#inicio" class="flex-shrink-0" aria-label="Velaris — Inicio">
      <img src="/images/white_logo_with_title_no_bg.png" alt="Velaris" class="hidden dark:block h-7 md:h-8 w-auto" />
      <img src="/images/black_logo_with_title_no_bg.png" alt="Velaris" class="block dark:hidden h-7 md:h-8 w-auto" />
    </a>

    <!-- Desktop nav links -->
    <ul class="hidden md:flex items-center gap-7 list-none m-0 p-0">
      {[
        ['#servicios', 'Servicios'],
        ['#tecnologia', 'Tecnología'],
        ['#valor', 'Valor'],
        ['#nosotros', 'Nosotros'],
      ].map(([href, label]) => (
        <li>
          <a href={href} class="nav-link text-sm font-medium transition-colors duration-200" style="color: var(--muted)">
            {label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Right: theme toggle + CTA + mobile hamburger -->
    <div class="flex items-center gap-3">

      <!-- Theme Toggle — always visible in light & dark mode -->
      <button
        id="theme-toggle"
        aria-label="Cambiar tema"
        class="theme-toggle-btn w-9 h-9 rounded-full flex items-center justify-center transition-all duration-200 hover:scale-110"
      >
        <!-- Sun icon: visible in DARK mode (click → switch to light) -->
        <svg id="icon-sun"
          xmlns="http://www.w3.org/2000/svg" width="17" height="17"
          fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"
          class="hidden dark:block">
          <circle cx="12" cy="12" r="5"/>
          <line x1="12" y1="1" x2="12" y2="3"/>
          <line x1="12" y1="21" x2="12" y2="23"/>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
          <line x1="1" y1="12" x2="3" y2="12"/>
          <line x1="21" y1="12" x2="23" y2="12"/>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
        <!-- Moon icon: visible in LIGHT mode (click → switch to dark) -->
        <svg id="icon-moon"
          xmlns="http://www.w3.org/2000/svg" width="16" height="16"
          fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"
          class="block dark:hidden">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>

      <!-- CTA (desktop) -->
      <a
        href="https://wa.me/573212545768?text=Hola%2C%20me%20interesa%20cotizar%20un%20proyecto%20con%20Velaris."
        target="_blank"
        rel="noopener noreferrer"
        id="nav-cta"
        class="btn-primary hidden md:inline-flex text-sm px-5 py-2.5"
      >
        Cotiza ahora
      </a>

      <!-- Mobile hamburger -->
      <button id="mobile-menu-btn" aria-label="Menú"
        class="md:hidden w-9 h-9 flex flex-col justify-center items-center gap-1.5 rounded-lg"
        style="background: var(--card); border: 1px solid var(--border);">
        <span class="block h-0.5 w-5 rounded-full transition-all duration-300" style="background: var(--text)"></span>
        <span class="block h-0.5 w-5 rounded-full transition-all duration-300" style="background: var(--text)"></span>
        <span class="block h-0.5 w-5 rounded-full transition-all duration-300" style="background: var(--text)"></span>
      </button>

    </div>
  </nav>

  <!-- Mobile menu drawer -->
  <div id="mobile-menu" class="md:hidden overflow-hidden transition-all duration-300"
    style="max-height: 0; border-top: 1px solid transparent;">
    <div class="px-5 py-5 flex flex-col gap-4" style="background: var(--surface);">
      <a href="#servicios" class="mobile-nav-link text-base font-medium py-2" style="color: var(--muted)">Servicios</a>
      <a href="#tecnologia" class="mobile-nav-link text-base font-medium py-2" style="color: var(--muted)">Tecnología</a>
      <a href="#valor" class="mobile-nav-link text-base font-medium py-2" style="color: var(--muted)">Valor</a>
      <a href="#nosotros" class="mobile-nav-link text-base font-medium py-2" style="color: var(--muted)">Nosotros</a>
      <a href="https://wa.me/573212545768?text=Hola%2C%20me%20interesa%20cotizar%20un%20proyecto%20con%20Velaris."
        target="_blank" rel="noopener noreferrer" class="btn-primary justify-center">
        Cotiza ahora
      </a>
    </div>
  </div>
</header>

<style>
  .nav-link:hover       { color: var(--accent) !important; }
  .mobile-nav-link:hover { color: var(--accent) !important; }
  #navbar               { background: transparent; }
</style>

<script is:inline>
  // ── Navbar scroll effect ─────────────────────────────
  var navbar = document.getElementById('navbar');
  window.addEventListener('scroll', function () {
    navbar.classList.toggle('nav-scrolled', window.scrollY > 20);
  });

  // ── Mobile menu ──────────────────────────────────────
  var mobileBtn  = document.getElementById('mobile-menu-btn');
  var mobileMenu = document.getElementById('mobile-menu');
  var menuOpen   = false;
  mobileBtn.addEventListener('click', function () {
    menuOpen = !menuOpen;
    mobileMenu.style.maxHeight    = menuOpen ? '400px' : '0';
    mobileMenu.style.borderTopColor = menuOpen ? 'var(--border)' : 'transparent';
  });
  document.querySelectorAll('.mobile-nav-link').forEach(function (link) {
    link.addEventListener('click', function () {
      menuOpen = false;
      mobileMenu.style.maxHeight = '0';
      mobileMenu.style.borderTopColor = 'transparent';
    });
  });

  // ── Theme toggle with ripple ─────────────────────────
  var themeBtn = document.getElementById('theme-toggle');
  var ripple   = document.getElementById('theme-ripple');

  themeBtn.addEventListener('click', function () {
    var isDark = document.documentElement.classList.contains('dark');
    var rect   = themeBtn.getBoundingClientRect();
    ripple.style.setProperty('--rx', (rect.left + rect.width  / 2) + 'px');
    ripple.style.setProperty('--ry', (rect.top  + rect.height / 2) + 'px');
    ripple.style.background = isDark ? '#F8FAFC' : '#080B10';
    ripple.classList.add('expanding');

    setTimeout(function () {
      document.documentElement.classList.toggle('dark');
      localStorage.setItem('velaris-theme',
        document.documentElement.classList.contains('dark') ? 'dark' : 'light');
    }, 320);

    ripple.addEventListener('animationend', function handler() {
      ripple.classList.remove('expanding');
      ripple.style.background = '';
      ripple.removeEventListener('animationend', handler);
    });
  });
</script>
