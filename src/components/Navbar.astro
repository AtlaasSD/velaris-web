---
---
<header id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <nav class="max-w-7xl mx-auto px-5 md:px-8 h-16 md:h-20 flex items-center justify-between gap-4">

    <!-- Logo -->
    <a href="#inicio" class="flex-shrink-0" aria-label="Velaris — Inicio">
      <img src="/images/white_logo_with_title_no_bg.png" alt="Velaris" class="hidden dark:block h-7 md:h-8 w-auto" />
      <img src="/images/black_logo_with_title_no_bg.png" alt="Velaris" class="block dark:hidden h-7 md:h-8 w-auto" />
    </a>

    <!-- Desktop nav links -->
    <ul class="hidden md:flex items-center gap-7 list-none m-0 p-0">
      {[
        ['#servicios', 'Servicios', 'Services'],
        ['#tecnologia', 'Tecnología', 'Technology'],
        ['#valor', 'Valor', 'Value'],
        ['#nosotros', 'Nosotros', 'About'],
      ].map(([href, label, enLabel]) => (
        <li>
          <a href={href} class="nav-link text-sm font-medium transition-colors duration-200" style="color: var(--muted)" data-en={enLabel}>
            {label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Right: theme toggle + CTA + mobile hamburger -->
    <div class="flex items-center gap-1.5 md:gap-3">

      <!-- Theme Toggle — always visible in light & dark mode -->
      <button
        id="theme-toggle"
        aria-label="Cambiar tema"
        class="theme-toggle-btn w-9 h-9 rounded-full flex items-center justify-center transition-all duration-200 hover:scale-110"
      >
        <!-- Sun icon: visible in DARK mode (click → switch to light) -->
        <svg id="icon-sun"
          xmlns="http://www.w3.org/2000/svg" width="17" height="17"
          fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"
          class="hidden dark:block">
          <circle cx="12" cy="12" r="5"/>
          <line x1="12" y1="1" x2="12" y2="3"/>
          <line x1="12" y1="21" x2="12" y2="23"/>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
          <line x1="1" y1="12" x2="3" y2="12"/>
          <line x1="21" y1="12" x2="23" y2="12"/>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
        <!-- Moon icon: visible in LIGHT mode (click → switch to dark) -->
        <svg id="icon-moon"
          xmlns="http://www.w3.org/2000/svg" width="16" height="16"
          fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"
          class="block dark:hidden">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>

      <!-- Language selector -->
      <div class="relative group" id="lang-selector">
        <button
          id="lang-menu-btn"
          aria-label="Cambiar idioma"
          aria-haspopup="true"
          aria-expanded="false"
          class="w-9 h-9 rounded-full flex items-center justify-center font-display font-bold text-xs transition-all duration-200 hover:scale-110"
          style="color: var(--text); border: 1px solid var(--border); background: var(--surface);"
        >
          ES
        </button>
        <!-- Dropdown Menu -->
        <div 
          id="lang-menu" 
          class="absolute top-full right-0 mt-2 w-24 py-1.5 rounded-xl shadow-lg opacity-0 invisible transition-all duration-200 translate-y-2 z-50 flex flex-col gap-0.5 px-1.5"
          style="background: var(--card); border: 1px solid var(--border);"
        >
          <button class="w-full text-center px-3 py-1.5 text-xs font-medium rounded-md transition-colors lang-option" data-lang="es" style="color: var(--text); background: var(--surface);">Español</button>
          <button class="w-full text-center px-3 py-1.5 text-xs font-medium rounded-md transition-colors lang-option hover:bg-opacity-50" data-lang="en" style="color: var(--muted);">English</button>
        </div>
      </div>

      <!-- CTA (desktop) -->
      <div class="mobile-hide">
        <a
          href="https://wa.me/573171509336?text=Hola%2C%20me%20interesa%20cotizar%20un%20proyecto%20con%20Velaris."
          target="_blank"
          rel="noopener noreferrer"
          id="nav-cta"
          class="btn-primary text-sm px-4 py-2"
          data-en="Get a Quote"
        >
          Cotiza ahora
        </a>
      </div>

      <!-- Mobile hamburger -->
      <button id="mobile-menu-btn" aria-label="Menú"
        class="md:hidden flex-shrink-0 w-9 h-9 flex flex-col justify-center items-center gap-1.5 rounded-lg"
        style="background: var(--card); border: 1px solid var(--border);">
        <span class="block h-0.5 w-5 rounded-full transition-all duration-300" style="background: var(--text)"></span>
        <span class="block h-0.5 w-5 rounded-full transition-all duration-300" style="background: var(--text)"></span>
        <span class="block h-0.5 w-5 rounded-full transition-all duration-300" style="background: var(--text)"></span>
      </button>

    </div>
  </nav>

  <!-- Mobile menu drawer -->
  <div id="mobile-menu" class="md:hidden overflow-hidden transition-all duration-300"
    style="max-height: 0; border-top: 1px solid transparent;">
    <div class="px-5 py-5 flex flex-col gap-4" style="background: var(--surface);">
      <a href="#servicios" class="mobile-nav-link text-base font-medium py-2" style="color: var(--muted)" data-en="Services">Servicios</a>
      <a href="#tecnologia" class="mobile-nav-link text-base font-medium py-2" style="color: var(--muted)" data-en="Technology">Tecnología</a>
      <a href="#valor" class="mobile-nav-link text-base font-medium py-2" style="color: var(--muted)" data-en="Value">Valor</a>
      <a href="#nosotros" class="mobile-nav-link text-base font-medium py-2" style="color: var(--muted)" data-en="About Us">Nosotros</a>
      <a href="https://wa.me/573171509336?text=Hola%2C%20me%20interesa%20cotizar%20un%20proyecto%20con%20Velaris."
        target="_blank" rel="noopener noreferrer" class="btn-primary justify-center" data-en="Get a Quote">
        Cotiza ahora
      </a>
    </div>
  </div>
</header>

<style>
  .nav-link:hover       { color: var(--accent) !important; }
  .mobile-nav-link:hover { color: var(--accent) !important; }
  #navbar               { background: transparent; }
  
  @media (max-width: 768px) {
    .mobile-hide { display: none !important; }
  }
  @media (min-width: 769px) {
    .mobile-hide { display: flex; }
  }
</style>

<script is:inline>
  // ── Navbar scroll effect ─────────────────────────────
  var navbar = document.getElementById('navbar');
  window.addEventListener('scroll', function () {
    navbar.classList.toggle('nav-scrolled', window.scrollY > 20);
  });

  // ── Mobile menu ──────────────────────────────────────
  var mobileBtn  = document.getElementById('mobile-menu-btn');
  var mobileMenu = document.getElementById('mobile-menu');
  var menuOpen   = false;
  mobileBtn.addEventListener('click', function () {
    menuOpen = !menuOpen;
    mobileMenu.style.maxHeight    = menuOpen ? '400px' : '0';
    mobileMenu.style.borderTopColor = menuOpen ? 'var(--border)' : 'transparent';
  });
  document.querySelectorAll('.mobile-nav-link').forEach(function (link) {
    link.addEventListener('click', function () {
      menuOpen = false;
      mobileMenu.style.maxHeight = '0';
      mobileMenu.style.borderTopColor = 'transparent';
    });
  });

  // ── Language Toggle Logic ────────────────────────────
  var langBtn = document.getElementById('lang-menu-btn');
  var langMenu = document.getElementById('lang-menu');
  var langMenuOpen = false;

  langBtn.addEventListener('click', function(e) {
    e.stopPropagation();
    langMenuOpen = !langMenuOpen;
    if (langMenuOpen) {
      langMenu.classList.remove('opacity-0', 'invisible', 'translate-y-2');
      langBtn.setAttribute('aria-expanded', 'true');
    } else {
      langMenu.classList.add('opacity-0', 'invisible', 'translate-y-2');
      langBtn.setAttribute('aria-expanded', 'false');
    }
  });

  document.addEventListener('click', function(e) {
    if (langMenuOpen && !document.getElementById('lang-selector').contains(e.target)) {
      langMenuOpen = false;
      langMenu.classList.add('opacity-0', 'invisible', 'translate-y-2');
      langBtn.setAttribute('aria-expanded', 'false');
    }
  });

  function updateButtonsStyle(lang) {
    document.querySelectorAll('.lang-option').forEach(function(btn) {
      if (btn.getAttribute('data-lang') === lang) {
        btn.style.background = 'var(--surface)';
        btn.style.color = 'var(--text)';
        btn.classList.remove('hover:bg-opacity-50');
      } else {
        btn.style.background = 'transparent';
        btn.style.color = 'var(--muted)';
        btn.classList.add('hover:bg-opacity-50');
      }
    });
  }

  document.querySelectorAll('.lang-option').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var selectedLang = this.getAttribute('data-lang');
      langBtn.innerText = selectedLang.toUpperCase();
      langMenuOpen = false;
      langMenu.classList.add('opacity-0', 'invisible', 'translate-y-2');
      langBtn.setAttribute('aria-expanded', 'false');
      
      updateButtonsStyle(selectedLang);
      
      // Update local storage and DOM translations
      localStorage.setItem('velaris-lang', selectedLang);
      document.documentElement.lang = selectedLang;
      applyTranslations(selectedLang);
    });
  });

  function applyTranslations(lang) {
    document.querySelectorAll('[data-en]').forEach(function(el) {
      if (!el.hasAttribute('data-es')) {
        el.setAttribute('data-es', el.innerHTML); // Backup original HTML
      }
      el.innerHTML = lang === 'en' ? el.getAttribute('data-en') : el.getAttribute('data-es');
    });
  }

  // Initial load language setup
  document.addEventListener('DOMContentLoaded', function() {
    var storedLang = localStorage.getItem('velaris-lang') || 'es';
    if (storedLang === 'en') {
      langBtn.innerText = 'EN';
      document.documentElement.lang = 'en';
      applyTranslations('en');
    }
    updateButtonsStyle(storedLang);
  });

  // ── Theme toggle with Shockwave Pulse ────────────────
  var themeBtn = document.getElementById('theme-toggle');
  var rippleContainer = document.getElementById('theme-ripple');

  themeBtn.addEventListener('click', function (e) {
    var isDark = document.documentElement.classList.contains('dark');
    var rect = themeBtn.getBoundingClientRect();
    
    var pulse = document.createElement('div');
    pulse.className = 'ripple-shockwave';
    pulse.style.setProperty('--rx', (rect.left + rect.width / 2) + 'px');
    pulse.style.setProperty('--ry', (rect.top + rect.height / 2) + 'px');
    
    if (rippleContainer) {
      rippleContainer.appendChild(pulse);
    }
    
    // Change theme smoothly at approx half the animation duration
    setTimeout(function() {
      document.documentElement.classList.toggle('dark');
      localStorage.setItem('velaris-theme', isDark ? 'light' : 'dark');
    }, 250);

    pulse.addEventListener('animationend', function() {
      pulse.remove();
    });
  });
</script>
