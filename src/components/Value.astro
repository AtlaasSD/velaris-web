---
const differentiators = [
  {
    icon: '🔑',
    title: 'Llave en mano', enTitle: 'Turnkey Solution',
    desc: 'Nos encargamos de todo el proceso técnico. Tú solo apruebas el diseño y nosotros hacemos el resto.', enDesc: 'We handle the entire technical process. You just approve the design and we do the rest.',
  },
  {
    icon: '⚡',
    title: 'Entrega ágil', enTitle: 'Agile Delivery',
    desc: 'Proyectos completados en tiempos récord sin sacrificar ni un detalle de calidad.', enDesc: 'Projects completed in record time without sacrificing a single detail of quality.',
  },
  {
    icon: '🛡️',
    title: 'Garantía de 1 año', enTitle: '1-Year Guarantee',
    desc: 'Mantenimiento y soporte técnico incluido durante el primer año. Tu inversión está protegida.', enDesc: 'Maintenance and technical support included during the first year. Your investment is protected.',
  },
  {
    icon: '📊',
    title: 'Proceso transparente', enTitle: 'Transparent Process',
    desc: 'Proyectos iniciados con el 50% de anticipo. Sin sorpresas, sin costos ocultos. Todo claro desde el inicio.', enDesc: 'Projects start with a 50% deposit. No surprises, no hidden costs. Everything clear from the start.',
  },
  {
    icon: '🌐',
    title: 'Hosting de alto rendimiento', enTitle: 'High-Performance Hosting',
    desc: 'Desplegamos en servidores globales de clase mundial. Tu sitio disponible 24/7 desde cualquier lugar.', enDesc: 'We deploy to world-class global servers. Your site available 24/7 from anywhere.',
  },
  {
    icon: '📈',
    title: 'Optimizado para Google', enTitle: 'Optimized for Google',
    desc: 'SEO técnico incluido de base. Tu negocio visible en las búsquedas que importan.', enDesc: 'Technical SEO included out of the box. Your business visible in searches that matter.',
  },
];

const postYearOptions = [
  {
    id: 'esencial',
    title: 'Mantenimiento Esencial', enTitle: 'Essential Maintenance',
    desc: 'Hosting activo para mantener tu sitio en línea y funcionando sin interrupciones.', enDesc: 'Active hosting to keep your site online and running without interruptions.',
    features: [
      { es: 'Hosting de alta disponibilidad', en: 'High-availability hosting' },
      { es: 'Monitoreo de uptime', en: 'Uptime monitoring' },
      { es: 'Actualizaciones de seguridad', en: 'Security updates' }
    ],
  },
  {
    id: 'premium',
    title: 'Soporte Premium', enTitle: 'Premium Support',
    desc: 'La tranquilidad de saber que tu presencia digital siempre está en las mejores manos.', enDesc: 'The peace of mind knowing your digital presence is always in the best hands.',
    features: [
      { es: 'Todo lo del plan Esencial', en: 'Everything in the Essential plan' },
      { es: 'Mantenimiento periódico', en: 'Periodic maintenance' },
      { es: 'Cambios de contenido (texto e imágenes)', en: 'Content updates (text and images)' },
      { es: 'Soporte técnico prioritario', en: 'Priority technical support' }
    ],
    highlight: true,
  },
];
---

<section id="valor" class="section-has-orbs py-24 md:py-32 px-5 md:px-8" style="background: var(--bg);">

  <!-- Ambient background orbs -->
  <div class="section-orbs" aria-hidden="true">
    <div class="blur-orb orb-c" style="width:420px;height:420px;background:#6C63FF;bottom:-100px;left:-130px;"></div>
    <div class="blur-orb" style="width:280px;height:280px;background:#22D3EE;top:-60px;right:-80px;"></div>
  </div>

  <div class="max-w-7xl mx-auto">

    <!-- Header -->
    <div class="text-center mb-14 md:mb-20">
      <p class="section-label reveal" data-en="Our Value">Nuestro Valor</p>
      <h2 class="font-display font-black text-3xl sm:text-4xl md:text-5xl mb-5 reveal reveal-delay-1" style="color: var(--text);" data-en="Elite technology,<br class='hidden sm:block' /> <span class='gradient-text'>smart investment</span>">
        Tecnología de élite,<br class="hidden sm:block" />
        <span class="gradient-text">inversión inteligente</span>
      </h2>
      <p class="max-w-2xl mx-auto text-base md:text-lg leading-relaxed reveal reveal-delay-2" style="color: var(--muted);" data-en="We believe entrepreneurs and SMBs deserve access to the same technology large companies use. That's why we offer <strong style='color: var(--text);'>the most competitive rates on the market</strong> without compromising a single pixel of quality.">
        Creemos que los emprendedores y PyMEs merecen acceso a la misma tecnología que usan las grandes empresas.
        Por eso ofrecemos <strong style="color: var(--text);">las tarifas más competitivas del mercado</strong> sin comprometer ni un píxel de calidad.
      </p>
    </div>

    <!-- Differentiators grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 mb-20">
      {differentiators.map((d, i) => (
        <div
          id={`diff-${i}`}
          class={`glow-card p-6 reveal reveal-delay-${(i % 3) + 1}`}
        >
          <div class="text-3xl mb-3" aria-hidden="true">{d.icon}</div>
          <h3 class="font-display font-bold text-lg mb-2" style="color: var(--text);" data-en={d.enTitle}>{d.title}</h3>
          <p class="text-sm leading-relaxed" style="color: var(--muted);" data-en={d.enDesc}>{d.desc}</p>
        </div>
      ))}
    </div>

    <!-- Post year 1 plans -->
    <div class="mb-16">
      <div class="text-center mb-10">
        <p class="section-label reveal" data-en="After the first year">Después del primer año</p>
        <h3 class="font-display font-bold text-2xl md:text-3xl reveal reveal-delay-1" style="color: var(--text);" data-en="We continue with you">
          Continuamos contigo
        </h3>
        <p class="max-w-lg mx-auto text-sm md:text-base mt-3 reveal reveal-delay-2" style="color: var(--muted);" data-en="Once the first year warranty ends, choose how to continue protecting your investment.">
          Una vez finalizado el primer año de garantía, elige cómo seguir protegiendo tu inversión.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-3xl mx-auto">
        {postYearOptions.map((plan, i) => (
          <div
            id={`plan-${plan.id}`}
            class={`glow-card p-7 flex flex-col reveal reveal-delay-${i + 1}`}
            style={plan.highlight ? 'border-color: rgba(108,99,255,0.4); background: linear-gradient(135deg, rgba(108,99,255,0.08), rgba(34,211,238,0.04));' : ''}
          >
            {plan.highlight && (
              <span class="self-start text-xs font-bold px-3 py-1 rounded-full mb-4"
                style="background: linear-gradient(135deg, #6C63FF, #22D3EE); color: #fff;" data-en="Recommended">
                Recomendado
              </span>
            )}
            <h4 class="font-display font-bold text-lg mb-2" style="color: var(--text);" data-en={plan.enTitle}>{plan.title}</h4>
            <p class="text-sm mb-5 leading-relaxed" style="color: var(--muted);" data-en={plan.enDesc}>{plan.desc}</p>
            <ul class="flex flex-col gap-2 flex-1">
              {plan.features.map(f => (
                <li class="flex items-start gap-2 text-sm" style="color: var(--muted);">
                  <svg width="15" height="15" viewBox="0 0 20 20" fill="none" class="mt-0.5 flex-shrink-0">
                    <path d="M5 10L8.5 13.5L15 7" stroke="#6C63FF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  <span data-en={f.en}>{f.es}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>

    <!-- Big CTA Block -->
    <div
      class="rounded-2xl p-8 md:p-14 text-center reveal reveal-delay-1"
      style="background: linear-gradient(135deg, rgba(108,99,255,0.13), rgba(34,211,238,0.07)); border: 1px solid rgba(108,99,255,0.25);"
    >
      <p class="section-label mb-3" data-en="Ready to start?">¿Listo para empezar?</p>
      <h3 class="font-display font-black text-2xl md:text-4xl mb-4" style="color: var(--text);" data-en="Tell us your vision.<br />We build the rest.">
        Cuéntanos tu visión.<br />Nosotros construimos el resto.
      </h3>
      <p class="max-w-lg mx-auto text-sm md:text-base mb-8" style="color: var(--muted);" data-en="No obligations. No hidden costs. Get a custom quote directly on WhatsApp and resolve all your doubts with our team.">
        Sin compromisos. Sin costos ocultos. Recibe una cotización personalizada directamente en WhatsApp y resuelve todas tus dudas con nuestro equipo.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="https://wa.me/573171509336?text=Hola%2C%20me%20interesa%20cotizar%20un%20proyecto%20web%20con%20Velaris."
          target="_blank"
          rel="noopener noreferrer"
          id="value-whatsapp-cta"
          class="btn-primary text-lg px-8 py-4"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
            <path d="M13.601 2.326A7.854 7.854 0 0 0 7.994 0C3.627 0 .068 3.558.064 7.926c0 1.399.366 2.76 1.057 3.965L0 16l4.204-1.102a7.933 7.933 0 0 0 3.79.965h.004c4.368 0 7.926-3.558 7.93-7.93A7.898 7.898 0 0 0 13.6 2.326zM7.994 14.521a6.573 6.573 0 0 1-3.356-.92l-.24-.144-2.494.654.666-2.433-.156-.251a6.56 6.56 0 0 1-1.007-3.505c0-3.626 2.957-6.584 6.591-6.584a6.56 6.56 0 0 1 4.66 1.931 6.557 6.557 0 0 1 1.928 4.66c-.004 3.639-2.961 6.592-6.592 6.592zm3.615-4.934c-.197-.099-1.17-.578-1.353-.646-.182-.065-.315-.099-.445.099-.133.197-.513.646-.627.775-.114.133-.232.148-.43.05-.197-.1-.836-.308-1.592-.985-.59-.525-.985-1.175-1.103-1.372-.114-.198-.011-.304.088-.403.087-.088.197-.232.296-.346.1-.114.133-.198.198-.33.065-.134.034-.248-.015-.347-.05-.099-.445-1.076-.612-1.47-.16-.389-.323-.335-.445-.34-.114-.007-.247-.007-.38-.007a.729.729 0 0 0-.529.247c-.182.198-.691.677-.691 1.654 0 .977.71 1.916.81 2.049.098.133 1.394 2.132 3.383 2.992.47.205.84.326 1.129.418.475.152.904.129 1.246.08.38-.058 1.171-.48 1.338-.943.164-.464.164-.86.114-.943-.049-.084-.182-.133-.38-.232z"/>
          <span data-en="Quote your project now">
            Cotiza tu proyecto ahora
          </span>
        </a>
        <a
          href="mailto:contactovelarisweb@gmail.com"
          id="value-email-cta"
          class="btn-secondary text-base px-8 py-4"
          data-en="Email us"
        >
          Escríbenos por correo
        </a>
      </div>
      <p class="mt-6 text-xs" style="color: var(--muted);" data-en="Projects start with a <strong>50% deposit</strong>. Response guaranteed in under 24 hours.">
        Los proyectos se inician con un <strong>anticipo del 50%</strong>. Respuesta garantizada en menos de 24 horas.
      </p>
    </div>

  </div>
</section>
